# Copy to .env and fill in. On Railway set these in the Variables tab.
JWT_SECRET=<run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))">
PORT=3000
NODE_ENV=production

# Google Sheets backend
SHEET_ID=<spreadsheet id from its URL>
# Paste the whole service-account JSON on one line (best for Railway):
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...or, for local dev, drop the key at ./service-account.json and set:
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
