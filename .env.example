# Copy to .env for local development.
# On Railway, set these in the service's Variables tab (DATABASE_URL is added
# automatically when you attach the PostgreSQL plugin).

# Required
JWT_SECRET=<run: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))">
NODE_ENV=production

# PostgreSQL. Local example below; on Railway this is provided by the plugin.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dams

# Optional
# PORT=3000                # Railway sets this automatically
# PGSSL=require            # force SSL on; use 'disable' to force off
